# ══════════════════════════════════════════════════
# Antigravity Clinic — Environment Variables
# Copy this file to .env.local and fill in values
# ══════════════════════════════════════════════════

# ── PerfectCorp / YouCam API (Server-side only) ──
# Get your API key from: https://developer.perfectcorp.com
PERFECTCORP_API_KEY=your-api-key-here

# Optional: Override the default API endpoint
# PERFECTCORP_API_URL=https://api.perfectcorp.com/v1/skin-analysis

# ── Public Variables (exposed to browser) ─────────
# WhatsApp contact number (with country code, no + prefix)
NEXT_PUBLIC_WHATSAPP_NUMBER=905321234567

# ── Optional: Site URL (Vercel sets this automatically) ──
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
